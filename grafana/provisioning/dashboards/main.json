        {
          "datasource": {
            "type": "postgres",
            "uid": "postgresql"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  block_number,\n  netuid,\n  CASE \n    WHEN call_function = 'dissolve_network' THEN 'Dissolution' \n    ELSE 'Registration' \n  END AS event_type,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'subnet_name' \n    ELSE NULL \n  END AS subnet_name,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'description' \n    ELSE NULL \n  END AS description,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'discord' \n    ELSE NULL \n  END AS discord,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'subnet_url' \n    ELSE NULL \n  END AS subnet_url,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'github_repo' \n    ELSE NULL \n  END AS github_repo,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'subnet_contact' \n    ELSE NULL \n  END AS subnet_contact,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'additional' \n    ELSE NULL \n  END AS additional,\n\n  CASE \n    WHEN call_function = 'register_network_with_identity' \n    THEN call_args[1]->'value'->>'logo_url' \n    ELSE NULL \n  END AS logo_url,\n\n  address AS signer\n\nFROM extrinsics\nWHERE call_function IN (\n    'register_network', \n    'register_network_with_identity', \n    'dissolve_network'\n)\n  AND block_timestamp BETWEEN ${__from} AND ${__to}\n\nORDER BY block_timestamp DESC\nLIMIT 100;",
          "refId": "A",
