          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n    netuid AS Subnet,\n    COUNT(*) FILTER (WHERE success) AS success,\n    COUNT(*) FILTER (WHERE NOT success) AS failures,\n    COUNT(*) AS total,\n    ROUND(\n        100.0 * COUNT(*) FILTER (WHERE NOT success) / COUNT(*),\n        2\n    ) AS failure_rate_pct\nFROM extrinsics\nWHERE call_function = 'set_weights'\n  AND block_timestamp BETWEEN ${__from} AND ${__to}\nGROUP BY netuid\nORDER BY failure_rate_pct DESC;",
