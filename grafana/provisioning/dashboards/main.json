        {
          "datasource": { "type": "postgres", "uid": "postgresql" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', to_timestamp(block_timestamp / 1000.0)) AS time,\n  CASE\n    WHEN call_function IN ('register_network', 'register_network_with_identity') THEN 'Registration'\n    WHEN call_function = 'dissolve_network' THEN 'Dissolution'\n    WHEN call_function IN ('announce_coldkey_swap', 'swap_coldkey_announced', 'dispute_coldkey_swap', 'reset_coldkey_swap', 'clear_coldkey_swap_announcement') THEN 'Coldkey Swap'\n    WHEN call_module = 'AdminUtils' THEN 'AdminUtils'\n    WHEN call_module = 'Sudo' THEN 'Sudo'\n  END AS metric,\n  COUNT(*) AS value\nFROM extrinsics\nWHERE block_timestamp BETWEEN ${__from} AND ${__to}\n  AND (\n    call_function IN ('register_network', 'register_network_with_identity', 'dissolve_network',\n      'announce_coldkey_swap', 'swap_coldkey_announced', 'dispute_coldkey_swap', 'reset_coldkey_swap', 'clear_coldkey_swap_announcement')\n    OR call_module IN ('AdminUtils', 'Sudo')\n  )\nGROUP BY time, metric\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Notification Events Over Time",
      "type": "timeseries"
    },

