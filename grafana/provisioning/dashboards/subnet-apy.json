          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT epoch_ts AS time, validator_name AS metric, apy_pct AS value FROM mv_subnet_validator_apy_epochs WHERE subnet_id = ${subnet} ORDER BY time",
          "refId": "A"
