        {
          "datasource": {
            "type": "postgres",
            "uid": "postgresql"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT epoch_ts AS time, 'Subnet avg' AS metric, (power(1 + SUM(alpha_dividends)::numeric / NULLIF(SUM(alpha_stake), 0), 2629800.0 / (MIN(tempo) + 1)) - 1) * 100 AS value FROM mv_subnet_validator_apy_epochs WHERE subnet_id = ${subnet} GROUP BY epoch_ts ORDER BY time",
