# ==============================================================================
# Django Core
# ==============================================================================

ENV=backend-dev
DEBUG=1
DEBUG_TOOLBAR=1
SECRET_KEY=12345
ALLOWED_HOSTS=localhost,127.0.0.1
LOG_LEVEL=INFO

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================

POSTGRES_DB=project
POSTGRES_PORT=8432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345

DATABASE_URL=postgres://postgres:12345@localhost:8432/project

# ==============================================================================
# Redis
# ==============================================================================


REDIS_HOST=localhost
REDIS_PORT=8379

# ==============================================================================
# Celery
# ==============================================================================

CELERY_BROKER_URL=redis://localhost:8379/0
CELERY_TASK_ALWAYS_EAGER=1
CELERY_TASK_EAGER_PROPAGATES=0
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_BROKER_POOL_LIMIT=50

# Worker concurrency (number of concurrent worker processes per queue)
CELERY_MASTER_CONCURRENCY=1
CELERY_METAGRAPH_CONCURRENCY=1

# Flower monitoring dashboard credentials
CELERY_FLOWER_USER=flower
CELERY_FLOWER_PASSWORD=12345

# ==============================================================================
# CORS
# ==============================================================================

CORS_ENABLED=1
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_ALL_ORIGINS=0

# ==============================================================================
# Bittensor
# ==============================================================================

# BITTENSOR_ARCHIVE_NETWORK=archive

SENTINEL_MODE=live
BLOCK_START=
BLOCK_END=
BACKFILL_RATE_LIMIT=1.0
BACKFILL_BATCH_SIZE=10
BACKFILL_BATCH_DELAY=1.0

# ==============================================================================
# Metagraph
# ==============================================================================

# Comma-separated list of subnet UIDs to sync (empty = all 1-128)
METAGRAPH_NETUIDS=
METAGRAPH_LITE=0

# Data retention windows in days; validator APY data is kept forever regardless.
# DATA_RETENTION_DAYS: non-validator neuron snapshots + mechanism metrics.
# DATA_RETENTION_BULK_DAYS: bulk tables (weight, bond, collateral, extrinsics).
DATA_RETENTION_DAYS=90
DATA_RETENTION_BULK_DAYS=40
DATA_RETENTION_BATCH_SIZE=20000
DATA_RETENTION_BATCH_SLEEP_SECONDS=0.2

# ==============================================================================
# Storage (S3)
# ==============================================================================

SENTINEL_STORAGE_S3_BUCKET=
SENTINEL_STORAGE_S3_BASE_PATH=
SENTINEL_STORAGE_S3_AWS_REGION=
SENTINEL_STORAGE_S3_AWS_ACCESS_KEY_ID=
SENTINEL_STORAGE_S3_AWS_SECRET_ACCESS_KEY=

# ==============================================================================
# Discord Alerts
# ==============================================================================

DISCORD_SUDO_ALERTS_WEBHOOK_URL=
DISCORD_ADMIN_UTILS_ALERTS_WEBHOOK_URL=
DISCORD_SUBNET_REGISTRATION_WEBHOOK_URL=
DISCORD_COLDKEY_SWAP_WEBHOOK_URL=

# ==============================================================================
# Monitoring (Grafana)
# ==============================================================================

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==============================================================================
# Sentry
# ==============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=development

PROMETHEUS_EXPORT_MIGRATIONS=0
HTTPS_REDIRECT=0

MEDIA_ROOT=media

# ==============================================================================
# Docker (cadvisor)
# ==============================================================================

DOCKER_ROOT_DIR=/var/lib/docker

# ==============================================================================
# Backups (Backblaze B2)
# ==============================================================================

BACKUP_LOCAL_ROTATE_KEEP_LAST=10
BACKUP_B2_BUCKET=
BACKUP_B2_FOLDER=
BACKUP_B2_APPLICATION_KEY_ID=
BACKUP_B2_APPLICATION_KEY=
